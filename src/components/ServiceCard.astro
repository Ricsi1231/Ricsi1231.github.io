---
import { Icon } from 'astro-icon/components';
import type { Service } from '../data/services';

type Props = Service;

const { icon, title, body } = Astro.props;
---

<div
  class="card rounded-[15px] border-2 border-transparent bg-card p-4 transition-all duration-300 hover:border-white hover:bg-card-hover"
>
  <span
    class="mb-4 inline-block rounded-[5px] bg-accent-dark px-[9px] py-[2px] text-[1.75rem] text-white"
  >
    <Icon name={icon} />
  </span>
  <h4 class="mb-2 text-[1.2rem] font-semibold text-white">{title}</h4>
  <p class="mb-4 text-muted" set:html={body} />
</div>
